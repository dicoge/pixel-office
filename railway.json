{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksVersion": "stable",
    "plan": {
      "nixpkgs": ["nodejs_20"]
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "environment": {
    "production": {
      "JWT_SECRET": {
        "description": "Secret key for JWT tokens",
        "value": "CHANGE_ME_IN_PRODUCTION"
      },
      "ALLOWED_ORIGINS": {
        "description": "Comma-separated list of allowed CORS origins",
        "value": "*"
      },
      "NODE_ENV": {
        "description": "Node environment",
        "value": "production"
      },
      "ADMIN_USERNAME": {
        "description": "Admin username for Pixel Office",
        "value": "dicoge"
      },
      "ADMIN_PASSWORD_HASH": {
        "description": "bcrypt hash of admin password",
        "value": "$2a$12$sfZH/ktpYsyrskw32PfBOOhLquqBfOzhejacqtKOoo1O8EF6TaBUm"
      }
    }
  }
}